# Configuration Manager — server environment.
# Copy this file to `.env` (which is gitignored) and fill in the values.
# The server loads `.env` on startup.

# Service account the app uses to connect to the instances and read their live configs.
# The password stays on the server; the UI only ever shows the username + a "configured" flag.
SERVICE_ACCOUNT_USER=
SERVICE_ACCOUNT_PASSWORD=

# Base URL of the web app, used in the links inside approval / recap emails.
APP_BASE_URL=http://localhost:5173

# Jira REST integration. Leave blank to use the built-in dev stub (fake CFG-#### keys).
# Basic auth = JIRA_EMAIL + JIRA_API_TOKEN. Config-change tickets are created under the
# epic set in the app (People page, default BSGPTALGO-550).
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_EMAIL=
JIRA_API_TOKEN=

# API port.
PORT=4000

# Dev only: impersonate this Windows ID when off-domain (defaults to "salavat").
CONFIG_MANAGER_DEV_USER=
